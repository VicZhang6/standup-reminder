{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "站立提醒",
  "version": "1.0.0",
  "identifier": "com.viczhang.standup-reminder",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "站立提醒",
        "url": "control.html",
        "width": 420,
        "height": 560,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
